# ==================== MyFood — secrets do servidor ====================
# Copie para "server.env" no servidor e preencha os valores reais.
# NUNCA comitar o server.env real.

# Banco (Postgres do host Docker, mesmo dos outros projetos)
ConnectionStrings__DefaultConnection=Host=172.17.0.1;Port=35432;Database=MyFood;Username=postgres;Password=SUA_SENHA_POSTGRES

# JWT — string longa e aleatória (mín. 32 caracteres)
JwtSecret=troque-por-uma-chave-longa-e-aleatoria-de-32+caracteres

# Admin criado no primeiro boot (você)
Admin__Email=seu-email@exemplo.com
Admin__Password=sua-senha-forte

# CORS — domínios liberados (front)
AllowedOrigins__0=http://localhost:3004

# ==================== IA (opcional) ====================
# Chave GRATUITA do Google AI Studio: https://aistudio.google.com/apikey
# Sem chave, o app funciona normal (preenchimento manual); com chave, aparece o botão "Analisar foto".
Gemini__ApiKey=
Gemini__Model=gemini-2.0-flash
